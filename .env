# 개발 환경용 더미 데이터 (실제 서비스 시 변경 필요)

# ─────────────────────────────────────────────────
# Web3Forms 이메일 전송 (https://web3forms.com)
# 1. web3forms.com 에서 이메일 입력 → Access Key 발급 (무료)
# 2. 아래 값을 발급받은 키로 교체하면 실제 이메일 수신 시작
# ─────────────────────────────────────────────────
VITE_WEB3FORMS_KEY=your_web3forms_access_key_here

VITE_FIREBASE_API_KEY=demo_api_key
VITE_FIREBASE_AUTH_DOMAIN=demo-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-project
VITE_FIREBASE_STORAGE_BUCKET=demo-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123def456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Notion API 설정 (개발용 더미)
VITE_NOTION_API_KEY=demo_notion_key
VITE_NOTION_SERVICES_DB_ID=demo_services_db
VITE_NOTION_INQUIRIES_DB_ID=demo_inquiries_db
VITE_NOTION_FAQS_DB_ID=demo_faqs_db
VITE_NOTION_EXPERIENCES_DB_ID=demo_experiences_db
VITE_NOTION_CERTIFICATIONS_DB_ID=demo_certifications_db
VITE_NOTION_TESTIMONIALS_DB_ID=demo_testimonials_db

# Google Forms 설정 (개발용 더미)
VITE_GOOGLE_FORM_ID=demo_form_id
VITE_GOOGLE_FORM_URL=https://docs.google.com/forms/d/demo_form_id/viewform

# 개발 모드 플래그
VITE_DEV_MODE=true